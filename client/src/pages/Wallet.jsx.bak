                      }`}>
                        <div className="flex items-center gap-2">
                          <FaExclamationTriangle className="w-4 h-4 text-amber-500" />
                          <p className={`text-sm ${theme === 'dark' ? 'text-amber-300' : 'text-amber-700'}`}>
                            Transactions may take 10-30 minutes to confirm depending on network.
                          </p>
                        </div>
                      </div>

                      {isExpired ? (
                        <motion.div
                          initial={{ opacity: 0, y: -10 }}
                          animate={{ opacity: 1, y: 0 }}
                          className={`p-4 rounded-xl ${
                            theme === 'dark'
                              ? 'bg-red-500/10 border border-red-500/30'
                              : 'bg-red-50 border border-red-200'
                          }`}
                        >
                          <div className="flex items-center gap-3">
                            <FaExclamationTriangle className="w-5 h-5 text-red-500" />
                            <p className={`text-sm ${theme === 'dark' ? 'text-red-300' : 'text-red-800'}`}>
                              Payment window has expired. Please generate a new deposit address.
                            </p>
                          </div>
                        </motion.div>
                      ) : (
                        <motion.div
                          initial={{ opacity: 0, y: -10 }}
                          animate={{ opacity: 1, y: 0 }}
                          className={`flex items-center justify-center gap-2 px-4 py-2 rounded-xl ${
                            timeLeft.minutes < 5
                              ? theme === 'dark'
                                ? 'bg-red-500/10 border border-red-500/30'
                                : 'bg-red-50 border border-red-200'
                              : theme === 'dark'
                                ? 'bg-white/5 border border-white/10'
                                : 'bg-gray-100 border border-gray-200'
                          }`}
                        >
                          <FiClock className={`w-4 h-4 ${timeLeft.minutes < 5 ? 'text-red-400' : theme === 'dark' ? 'text-white/60' : 'text-gray-500'}`} />
                          <span className={`text-sm font-medium ${timeLeft.minutes < 5 ? 'text-red-400' : theme === 'dark' ? 'text-white/80' : 'text-gray-600'}`}>
                            Time remaining: {String(timeLeft.minutes).padStart(2, '0')}:{String(timeLeft.seconds).padStart(2, '0')}
                          </span>
                        </motion.div>
                      )}

                      <motion.div
                        initial={{ opacity: 0, y: 20 }}
                        animate={{ opacity: 1, y: 0 }}
                        className={`rounded-2xl p-5 ${
                          theme === 'dark'
                            ? 'bg-gradient-to-br from-yellow-500/10 to-amber-500/5 border border-yellow-500/20'
                            : 'bg-gradient-to-br from-yellow-50 to-amber-50 border border-yellow-200'
                        }`}
                      >
                        <div className="flex items-center gap-2 mb-2">
                          <div className={`w-6 h-6 rounded-lg bg-gradient-to-br ${selectedCoin?.color} flex items-center justify-center text-white text-xs font-bold`}>
                            {selectedCoin?.icon}
                          </div>
                          <span className={`text-sm font-medium ${theme === 'dark' ? 'text-white/60' : 'text-gray-500'}`}>
                            Deposit Amount
                          </span>
                        </div>
                        <div className="flex items-baseline gap-2">
                          <span className={`text-3xl font-black ${theme === 'dark' ? 'text-white' : 'text-gray-900'}`}>
                            0.025
                          </span>
                          <span className={`text-lg font-bold ${selectedCoin?.textColor || 'text-yellow-500'}`}>
                            {selectedCoin?.symbol}
                          </span>
                        </div>
                        <div className={`text-sm ${theme === 'dark' ? 'text-white/50' : 'text-gray-500'}`}>
                          ≈ $1,687.50 USD
                        </div>
                      </motion.div>

                      <div className="flex items-center justify-center gap-2">
                        <div className={`px-3 py-1.5 rounded-full text-xs font-medium flex items-center gap-2 ${
                          theme === 'dark'
                            ? 'bg-white/5 border border-white/10'
                            : 'bg-gray-100 border border-gray-200'
                        }`}>
                          <div className={`w-5 h-5 rounded-full bg-gradient-to-br ${selectedCoin?.color} flex items-center justify-center text-white text-[10px] font-bold`}>
                            {selectedCoin?.icon}
                          </div>
                          <span className={theme === 'dark' ? 'text-white' : 'text-gray-900'}>
                            {selectedCoin?.name} ({selectedCoin?.symbol})
                          </span>
                        </div>
                        <div className={`px-3 py-1.5 rounded-full text-xs flex items-center gap-2 ${
                          theme === 'dark'
                            ? 'bg-emerald-500/10 text-emerald-400 border border-emerald-500/20'
                            : 'bg-emerald-50 text-emerald-600 border border-emerald-200'
                        }`}>
                          <FaLock className="w-3 h-3" />
                          <span>Secure</span>
                        </div>
                      </div>

                      <motion.div
                        initial={{ opacity: 0, y: 20 }}
                        animate={{ opacity: 1, y: 0 }}
                        transition={{ delay: 0.1 }}
                        className={`rounded-2xl p-5 ${
                          theme === 'dark'
                            ? 'bg-white/5 border border-white/10'
                            : 'bg-gray-50 border border-gray-200'
                        }`}
                      >
                        <div className="flex items-center justify-between mb-4">
                          <div className="flex items-center gap-2">
                            <FaWallet className={`w-4 h-4 ${selectedCoin?.textColor || 'text-yellow-400'}`} />
                            <span className={`font-semibold ${theme === 'dark' ? 'text-white' : 'text-gray-900'}`}>
                              Wallet Address
                            </span>
                          </div>
                        </div>
                        <div className={`p-3 rounded-xl flex items-center justify-between gap-2 ${
                          theme === 'dark' ? 'bg-black/20' : 'bg-white border border-gray-200'
                        }`}>
                          <code className={`text-sm font-mono break-all flex-1 ${theme === 'dark' ? 'text-white/80' : 'text-gray-700'}`}>
                            {selectedCoin?.address || 'bc1qxy2kgdygjrsqtzq2n0yrf2493p83kkfjhx0wlh'}
                          </code>
                          <motion.button
                            whileHover={{ scale: 1.1 }}
                            whileTap={{ scale: 0.9 }}
                            onClick={() => {
                              navigator.clipboard.writeText(selectedCoin?.address || '')
                              notify('Address copied!')
                            }}
                            className={`p-2 rounded-lg flex-shrink-0 ${
                              theme === 'dark'
                                ? 'bg-white/5 hover:bg-white/10'
                                : 'bg-gray-100 hover:bg-gray-200'
                            }`}
                          >
                            <FaCopyIcon className="w-4 h-4" />
                          </motion.button>
                        </div>
                        <motion.div
                          initial={{ opacity: 0 }}
                          animate={{ opacity: 1 }}
                          transition={{ delay: 0.2 }}
                          className={`mt-4 p-3 rounded-xl ${
                            theme === 'dark'
                              ? 'bg-amber-500/10 border border-amber-500/20'
                              : 'bg-amber-50 border border-amber-200'
                          }`}
                        >
                          <div className="flex items-start gap-2">
                            <FaExclamationTriangle className="w-4 h-4 text-amber-500 mt-0.5" />
                            <p className={`text-xs ${theme === 'dark' ? 'text-amber-300' : 'text-amber-700'}`}>
                              Only send <span className="font-bold">{selectedCoin?.symbol}</span> to this address. Sending other assets may result in permanent loss.
                            </p>
                          </div>
                        </motion.div>
                      </motion.div>

                      <motion.div
                        initial={{ opacity: 0, y: 20 }}
                        animate={{ opacity: 1, y: 0 }}
                        transition={{ delay: 0.2 }}
                        className={`rounded-2xl p-5 ${
                          theme === 'dark'
                            ? 'bg-white/5 border border-white/10'
                            : 'bg-gray-50 border border-gray-200'
                        }`}
                      >
                        <div className="flex items-center justify-between mb-4">
                          <div className="flex items-center gap-2">
                            <FaQrcode className={`w-4 h-4 ${selectedCoin?.textColor || 'text-yellow-400'}`} />
                            <span className={`font-semibold ${theme === 'dark' ? 'text-white' : 'text-gray-900'}`}>
                              Scan QR Code
                            </span>
                          </div>
                        </div>
                        <div className="flex justify-center">
                          <div className={`p-4 rounded-2xl ${theme === 'dark' ? 'bg-white' : 'bg-white border border-gray-200'} shadow-sm`}>
                            <QRCodeSVG
                              value={selectedCoin?.address || 'cryptofx:address'}
                              size={140}
                              level="H"
                              bgColor={theme === 'dark' ? '#ffffff' : '#ffffff'}
                              fgColor={theme === 'dark' ? '#000000' : '#000000'}
                            />
                          </div>
                        </div>
                      </motion.div>

                      <motion.div
                        initial={{ opacity: 0, y: 20 }}
                        animate={{ opacity: 1, y: 0 }}
                        transition={{ delay: 0.3 }}
                        className={`rounded-2xl p-5 ${
                          theme === 'dark'
                            ? 'bg-white/5 border border-white/10'
                            : 'bg-gray-50 border border-gray-200'
                        }`}
                      >
                        <div className="flex items-center gap-2 mb-4">
                          <FaUpload className={`w-4 h-4 ${selectedCoin?.textColor || 'text-yellow-400'}`} />
                          <span className={`font-semibold ${theme === 'dark' ? 'text-white' : 'text-gray-900'}`}>
                            Proof of Payment
                          </span>
                        </div>
                        <input
                          type="file"
                          accept="image/*"
                          onChange={(e) => e.target.files[0] && handleFileUpload(e.target.files[0])}
                          className="hidden"
                          id="proof-upload"
                        />
                        {!uploadedFile ? (
                          <label
                            htmlFor="proof-upload"
                            className={`block border-2 border-dashed rounded-xl p-8 text-center cursor-pointer transition-all ${
                              theme === 'dark'
                                ? 'border-white/10 hover:border-yellow-500/30 bg-white/5'
                                : 'border-gray-200 hover:border-yellow-400 bg-gray-50'
                            }`}
                          >
                            <FaUpload className={`w-8 h-8 mx-auto mb-3 ${theme === 'dark' ? 'text-white/40' : 'text-gray-400'}`} />
                            <p className={`font-medium mb-1 ${theme === 'dark' ? 'text-white' : 'text-gray-900'}`}>
                              Upload Screenshot
                            </p>
                            <p className={`text-sm ${theme === 'dark' ? 'text-white/40' : 'text-gray-400'}`}>
                              PNG, JPG up to 10MB
                            </p>
                          </label>
                        ) : (
                          <div className={`rounded-xl overflow-hidden ${theme === 'dark' ? 'bg-black/20' : 'bg-white border border-gray-200'}`}>
                            <img src={URL.createObjectURL(uploadedFile)} alt="Proof" className="w-full h-32 object-cover" />
                            <div className="p-3 flex items-center justify-between">
                              <span className={`text-sm truncate ${theme === 'dark' ? 'text-white/60' : 'text-gray-600'}`}>
                                {uploadedFile.name}
                              </span>
                              <motion.button
                                whileHover={{ scale: 1.1 }}
                                whileTap={{ scale: 0.9 }}
                                onClick={() => setUploadedFile(null)}
                                className="p-1.5 rounded-lg bg-red-500/20 text-red-400 hover:bg-red-500/30"
                              >
                                <FaTimes className="w-4 h-4" />
                              </motion.button>
                            </div>
                          </div>
                        )}
                      </motion.div>
                    </div>

                    <div className={`p-4 space-y-3 ${
                      theme === 'dark' ? 'bg-black/20 border-t border-white/5' : 'bg-gray-50 border-t border-gray-100'
                    }`}>
                      <motion.button
                        whileHover={!isExpired && !isConfirming ? { scale: 1.02, boxShadow: '0 20px 40px -10px rgba(234, 179, 8, 0.4)' } : {}}
                        whileTap={!isExpired && !isConfirming ? { scale: 0.98 } : {}}
                        onClick={handleConfirm}
                        disabled={isExpired || isConfirming || transactionStatus === 'completed'}
                        className={`w-full py-4 rounded-2xl font-bold text-lg flex items-center justify-center gap-3 transition-all ${
                          isExpired || transactionStatus === 'completed'
                            ? theme === 'dark'
                              ? 'bg-white/10 text-white/40 cursor-not-allowed'
                              : 'bg-gray-200 text-gray-400 cursor-not-allowed'
                            : 'bg-gradient-to-r from-yellow-500 to-amber-500 text-white shadow-xl shadow-yellow-500/30 hover:shadow-yellow-500/50'
                        }`}
                      >
                        {isConfirming ? (
                          <>
                            <motion.div
                              animate={{ rotate: 360 }}
                              transition={{ duration: 1, repeat: Infinity, ease: 'linear' }}
                              className="w-6 h-6 border-2 border-white border-t-transparent rounded-full"
                            />
                            Processing...
                          </>
                        ) : transactionStatus === 'completed' ? (
                          <>
                            <FaCheckCircle className="w-6 h-6" />
                            Deposit Confirmed
                          </>
                        ) : (
                          <>
                            <FaWallet className="w-6 h-6" />
                            Confirm Deposit
                          </>
                        )}
                      </motion.button>
                      
                      <div className="flex items-center justify-center gap-3">
                        <motion.button
                          whileHover={{ scale: 1.05 }}
                          whileTap={{ scale: 0.95 }}
                          onClick={resetDeposit}
                          className={`flex items-center gap-2 px-4 py-2 rounded-xl text-sm font-medium ${
                            theme === 'dark'
                              ? 'bg-white/5 hover:bg-white/10 text-white/60'
                              : 'bg-gray-100 hover:bg-gray-200 text-gray-600'
                          }`}
                        >
                          <FaRedo className="w-4 h-4" />
                          New Address
                        </motion.button>
                        <motion.button
                          whileHover={{ scale: 1.05 }}
                          whileTap={{ scale: 0.95 }}
                          className={`flex items-center gap-2 px-4 py-2 rounded-xl text-sm font-medium ${
                            theme === 'dark'
                              ? 'bg-white/5 hover:bg-white/10 text-white/60'
                              : 'bg-gray-100 hover:bg-gray-200 text-gray-600'
                          }`}
                        >
                          <FaHeadset className="w-4 h-4" />
                          Get Help
                        </motion.button>
                      </div>
                    </div>
                  </motion.div>
                )}
              </AnimatePresence>
            </motion.div>
          </motion.div>
        </AnimatePresence>
      )}

      {showWithdrawModal && (
        <motion.div
          initial={{ opacity: 0 }}
          animate={{ opacity: 1 }}
          exit={{ opacity: 0 }}
          className="fixed inset-0 bg-black/50 backdrop-blur-sm flex items-center justify-center z-50 p-4"
        >
          <motion.div
            initial={{ opacity: 0, scale: 0.95 }}
            animate={{ opacity: 1, scale: 1 }}
            className="card w-full max-w-md"
          >
            <h2 className="text-xl font-semibold text-white mb-6">Withdraw Funds</h2>
            <form onSubmit={handleWithdraw} className="space-y-4">
              <div>
                <label className="block text-sm text-gray-400 mb-2">Amount</label>
                <input
                  type="number"
                  value={amount}
                  onChange={(e) => setAmount(e.target.value)}
                  className="input-field"
                  placeholder="0.00"
                  required
                />
              </div>
              <div>
                <label className="block text-sm text-gray-400 mb-2">Method</label>
                <div className="grid grid-cols-2 gap-3">
                  {['bank', 'crypto'].map((m) => (
                    <button
                      key={m}
                      type="button"
                      onClick={() => setMethod(m)}
                      className={`py-3 rounded-xl font-medium capitalize ${
                        method === m
                          ? 'bg-primary text-dark-950'
                          : 'bg-dark-800 text-gray-400 hover:text-white'
                      }`}
                    >
                      {m}
                    </button>
                  ))}
                </div>
              </div>
              <p className="text-xs text-gray-500">A 1% withdrawal fee applies</p>
              <div className="flex gap-3 pt-4">
                <button
                  type="button"
                  onClick={() => setShowWithdrawModal(false)}
                  className="btn-secondary flex-1"
                >
                  Cancel
                </button>
                <button
                  type="submit"
                  disabled={processing}
                  className="btn-primary flex-1"
                >
                  {processing ? 'Processing...' : 'Withdraw'}
                </button>
              </div>
            </form>
          </motion.div>
        </motion.div>
      )}
    </div>
  )
}
