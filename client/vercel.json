{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "https://cryptofxtrading.up.railway.app/api/$1"
    },
    {
      "src": "/socket.io/(.*)",
      "dest": "https://cryptofxtrading.up.railway.app/socket.io/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
