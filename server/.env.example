# Server Configuration
PORT=5001
MONGODB_URI=mongodb://127.0.0.1:27017/cryptofx
CLIENT_URL=http://localhost:5173

# JWT Secret (IMPORTANT: Change this to a strong random string in production!)
JWT_SECRET=CHANGE_THIS_TO_A_STRONG_RANDOM_SECRET_IN_PRODUCTION

# Superadmin Credentials (IMPORTANT: Change these in production!)
SUPERADMIN_EMAIL=superadmin@yourdomain.com
SUPERADMIN_PASSWORD=CHANGE_THIS_PASSWORD
SUPERADMIN_PIN=CHANGE_THIS_PIN

# Google OAuth (Get these from Google Cloud Console)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# External APIs (Optional)
BINANCE_API_KEY=your-binance-api-key
BINANCE_SECRET_KEY=your-binance-secret-key
